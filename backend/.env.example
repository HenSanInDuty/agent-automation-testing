# ══════════════════════════════════════════════════════════════════════════════
# Auto-AT Backend — Environment Variables (V3)
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# All variables have sensible defaults for local development.
# In production, override at minimum:
#   - MONGODB_URI (use a real auth URI)
#   - SECRET_KEY (use a long random string)
#   - DEFAULT_LLM_API_KEY (or set per-profile in the Admin UI)
#   - ENCRYPT_API_KEYS=true
#   - APP_ENV=production
#   - MOCK_CREWS=false
#
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=3.0.0
APP_TITLE=Auto-AT API
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── MongoDB ───────────────────────────────────────────────────────────────────
# For local dev (no auth):
MONGODB_URI=mongodb://localhost:27017
# For Docker Compose (with auth):
# MONGODB_URI=mongodb://admin:changeme@localhost:27017/auto_at?authSource=admin
MONGODB_DB_NAME=auto_at

# ── Default LLM Fallback ──────────────────────────────────────────────────────
# Used when no LLM profile is set as default in the Admin UI.
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=sk-...
# DEFAULT_LLM_BASE_URL=          # Custom endpoint (Ollama, Azure, vLLM, etc.)
DEFAULT_LLM_TEMPERATURE=0.1
DEFAULT_LLM_MAX_TOKENS=2048

# ── LLM Provider Keys (shortcuts — you can also set them per-profile in the UI)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
# When true, API keys stored in the DB are encrypted at rest
ENCRYPT_API_KEYS=false

# ── Seeding ───────────────────────────────────────────────────────────────────
# Automatically seed default LLM profiles, agent configs, and pipeline
# templates on startup (idempotent — safe to leave enabled in production).
AUTO_SEED=true

# ── Pipeline / DAG Runner (V3) ────────────────────────────────────────────────
# When true, all crews return deterministic mock output without calling any LLM.
# Useful for CI and Windows dev (no crewai wheels required).
MOCK_CREWS=false

# Maximum number of pipeline runs allowed to execute concurrently.
MAX_CONCURRENT_RUNS=3

# Default per-node execution timeout (seconds).  Overridable per-node in the
# pipeline template.  Must be between 10 and 7200.
NODE_DEFAULT_TIMEOUT=300

# Maximum nodes allowed to run in parallel within a single DAG layer.
# Set to 1 to force fully sequential execution.
MAX_PARALLEL_NODES=10

# Auto-cancel a pipeline run that stays paused longer than this many seconds.
PAUSE_TIMEOUT_SECONDS=3600

# ── V2 Legacy Stage Timeouts (kept for backward compatibility) ─────────────────
# These control the built-in stage crews when running V2-style pipeline starts.
INGESTION_TIMEOUT_SECONDS=120
TESTCASE_TIMEOUT_SECONDS=600
EXECUTION_TIMEOUT_SECONDS=300
REPORTING_TIMEOUT_SECONDS=180

# ── Ingestion (chunking) ──────────────────────────────────────────────────────
INGESTION_CHUNK_SIZE=2000
INGESTION_CHUNK_OVERLAP=200
