# ══════════════════════════════════════════════════════════════
#  Auto-AT Backend – Environment Variables  (V2)
#  Copy this file to .env and fill in real values.
#  Lines starting with # are comments and are ignored.
# ══════════════════════════════════════════════════════════════


# ── Application ───────────────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8000
APP_HOST=0.0.0.0
APP_TITLE=Auto-AT API
APP_VERSION=2.0.0

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001


# ── MongoDB (V2 — replaces V1 SQLite DATABASE_URL) ────────────
#
#  Local development (no auth):
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=auto_at
#
#  Local development with Docker Compose:
# MONGODB_URI=mongodb://admin:changeme@localhost:27017/auto_at?authSource=admin
# MONGODB_DB_NAME=auto_at
#
#  Production / Docker Compose (service-name hostname):
# MONGODB_URI=mongodb://admin:${MONGO_PASSWORD}@mongodb:27017/auto_at?authSource=admin
# MONGODB_DB_NAME=auto_at
#
#  MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=auto_at


# ── Default LLM fallback ──────────────────────────────────────
#  Used when no LLM profile is marked is_default=True in the DB.
#  Supported providers: openai | anthropic | ollama | groq | huggingface | azure_openai
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=sk-...
DEFAULT_LLM_BASE_URL=            # Required for Ollama / Azure / LM Studio / vLLM
DEFAULT_LLM_TEMPERATURE=0.1
DEFAULT_LLM_MAX_TOKENS=2048


# ── File upload ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50


# ── Security ──────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
ENCRYPT_API_KEYS=false          # Set true in production to encrypt API keys at rest


# ── Seeding ───────────────────────────────────────────────────
#  When true, seeds default LLM profile + 19 agent configs + 4 stage configs
#  on every startup (idempotent — existing documents are not overwritten).
AUTO_SEED=true


# ── Pipeline / Crews ──────────────────────────────────────────
#  Set MOCK_CREWS=true to skip real LLM calls and return deterministic
#  mock output. Useful on Windows (no crewai wheels) and in CI.
MOCK_CREWS=false
MAX_CONCURRENT_RUNS=3

#  Per-stage execution timeouts in seconds (0 = no timeout)
INGESTION_TIMEOUT_SECONDS=120
TESTCASE_TIMEOUT_SECONDS=600
EXECUTION_TIMEOUT_SECONDS=300
REPORTING_TIMEOUT_SECONDS=180

#  Ingestion chunking
INGESTION_CHUNK_SIZE=2000
INGESTION_CHUNK_OVERLAP=200


# ── Pause / Resume (Feature 7) ────────────────────────────────
#  If a pipeline stays paused longer than this, it is auto-cancelled.
PAUSE_TIMEOUT_SECONDS=3600       # 3600 = 1 hour
